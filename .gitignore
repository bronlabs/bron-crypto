/.run/

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Preprocessed file by sage
*.sage.py

# Dependency directories (remove the comment below to include it)
vendor/
venv/

# Editors
.idea/
testdata/
.*.swp
.*.sw?
.#*
\#*

# Visual Studio Code
.vscode/*
!.vscode/settings.json

# Mac
.DS_Store

# Latex
docs/build/*
!docs/build/main.pdf

# golangci-lint Cache
/.golangcicache
/.gocache

# BoringSSL
/thirdparty/boringssl

# Claude
**/.claude/
!/.claude/skills/
!/.claude/skills/**
/.claude/settings.local.json
/.claude/local/
/.claude/*.local.md

# Codex
**/.agents/
!/.agents/
!/.agents/skills/**

# Misc.
/docs/papers
/coverage.out
/coverage.html
